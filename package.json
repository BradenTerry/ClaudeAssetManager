{
  "name": "claude-asset-manager",
  "displayName": "Claude Asset Manager",
  "description": "Discover and browse all Claude Code assets across your machine",
  "version": "0.0.0-dev",
  "publisher": "BradenTerry",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BradenTerry/ClaudeAssetManager.git"
  },
  "homepage": "https://github.com/BradenTerry/ClaudeAssetManager#readme",
  "bugs": {
    "url": "https://github.com/BradenTerry/ClaudeAssetManager/issues"
  },
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "skills",
    "agents",
    "commands",
    "plugins",
    "assets"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-assets",
          "title": "Claude Asset Manager",
          "icon": "media/claude-assets.svg"
        }
      ]
    },
    "views": {
      "claude-assets": [
        {
          "id": "claudeAssets.global",
          "name": "Global",
          "icon": "media/claude-assets.svg",
          "contextualTitle": "Claude Asset Manager"
        },
        {
          "id": "claudeAssets.workingDirectory",
          "name": "Working Directory",
          "icon": "media/claude-assets.svg",
          "contextualTitle": "Claude Asset Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeAssets.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.addDirectory",
        "title": "Add Directory",
        "icon": "$(add)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.removeDirectory",
        "title": "Remove Directory",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.openFile",
        "title": "Open File",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.openPreview",
        "title": "Open Preview",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.revealInOS",
        "title": "Reveal in File Manager",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.deleteFile",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.updatePlugin",
        "title": "Update Plugin",
        "icon": "$(arrow-circle-down)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.updateAllPlugins",
        "title": "Update All Plugins",
        "icon": "$(arrow-circle-down)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.updateMarketplacePlugins",
        "title": "Update Plugins",
        "icon": "$(arrow-circle-down)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.uninstallPlugin",
        "title": "Uninstall Plugin",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.enablePlugin",
        "title": "Enable Plugin",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.disablePlugin",
        "title": "Disable Plugin",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.addMarketplace",
        "title": "Add Marketplace",
        "icon": "$(add)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.removeMarketplace",
        "title": "Remove Marketplace",
        "icon": "$(trash)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.refreshMarketplace",
        "title": "Refresh Source",
        "icon": "$(sync)",
        "category": "Claude Asset Manager"
      },
      {
        "command": "claudeAssets.browseMarketplace",
        "title": "Add Plugin",
        "icon": "$(add)",
        "category": "Claude Asset Manager"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeAssets.refresh",
          "when": "view == claudeAssets.global || view == claudeAssets.workingDirectory",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeAssets.openFile",
          "when": "(view == claudeAssets.global || view == claudeAssets.workingDirectory) && (viewItem =~ /^asset-(md|config)-/ || viewItem =~ /^fsFile/)",
          "group": "open"
        },
        {
          "command": "claudeAssets.openPreview",
          "when": "(view == claudeAssets.global || view == claudeAssets.workingDirectory) && (viewItem =~ /^asset-md-/ || viewItem =~ /^fsFileMd/)",
          "group": "open"
        },
        {
          "command": "claudeAssets.revealInOS",
          "when": "(view == claudeAssets.global || view == claudeAssets.workingDirectory) && (viewItem =~ /^asset-(md|config)-/ || viewItem =~ /^fs(Dir|File)/ || viewItem == assetPluginsRoot || viewItem == assetPluginsRootOutdated || viewItem == assetProjectsRoot || viewItem == assetMarketplace || viewItem == assetMarketplaceOutdated)",
          "group": "reveal"
        },
        {
          "command": "claudeAssets.removeDirectory",
          "when": "(view == claudeAssets.global || view == claudeAssets.workingDirectory) && viewItem == registeredRoot",
          "group": "manage"
        },
        {
          "command": "claudeAssets.updatePlugin",
          "when": "view == claudeAssets.global && viewItem =~ /^assetPluginFolder.*Outdated$/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.uninstallPlugin",
          "when": "view == claudeAssets.global && viewItem =~ /^assetPluginFolder(Enabled|Disabled)/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.enablePlugin",
          "when": "view == claudeAssets.global && viewItem =~ /^assetPluginFolderDisabled/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.disablePlugin",
          "when": "view == claudeAssets.global && viewItem =~ /^assetPluginFolderEnabled/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.addMarketplace",
          "when": "view == claudeAssets.global && viewItem =~ /^assetPluginsRoot/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.browseMarketplace",
          "when": "view == claudeAssets.global && viewItem =~ /^assetMarketplace/",
          "group": "inline"
        },
        {
          "command": "claudeAssets.browseMarketplace",
          "when": "view == claudeAssets.global && viewItem =~ /^assetMarketplace/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.refreshMarketplace",
          "when": "view == claudeAssets.global && viewItem =~ /^assetMarketplace/",
          "group": "manage"
        },
        {
          "command": "claudeAssets.removeMarketplace",
          "when": "view == claudeAssets.global && viewItem =~ /^assetMarketplace/",
          "group": "zzz_delete"
        },
        {
          "command": "claudeAssets.updateAllPlugins",
          "when": "view == claudeAssets.global && viewItem == assetPluginsRootOutdated",
          "group": "manage"
        },
        {
          "command": "claudeAssets.updateMarketplacePlugins",
          "when": "view == claudeAssets.global && viewItem == assetMarketplaceOutdated",
          "group": "manage"
        },
        {
          "command": "claudeAssets.deleteFile",
          "when": "(view == claudeAssets.global || view == claudeAssets.workingDirectory) && (viewItem =~ /^asset-(md|config)-(global|project|registered)/ || viewItem == fsFile || viewItem == fsFileMd || viewItem == fsDir)",
          "group": "zzz_delete"
        }
      ]
    },
    "configuration": {
      "title": "Claude Asset Manager",
      "properties": {
        "claudeAssets.directories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories to scan for Claude assets."
        },
        "claudeAssets.followSymlinks": {
          "type": "boolean",
          "default": true,
          "description": "Follow symbolic links when scanning for assets."
        },
        "claudeAssets.excludeDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "bin",
            "obj",
            "dist",
            "target",
            ".venv",
            "venv",
            ".idea",
            ".vs"
          ],
          "description": "Directory names to exclude from recursive scans."
        },
        "claudeAssets.maxDepth": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "description": "Maximum directory depth to search for a .claude directory. Once a .claude directory is found, its entire contents are scanned regardless of this limit."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node20 --minify --sourcemap",
    "test": "npm run compile && TS_NODE_PROJECT=tsconfig.test.json mocha",
    "vscode:prepublish": "npm run bundle",
    "package": "npx --yes @vscode/vsce package --readme-path MARKETPLACE.md"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.0",
    "mocha": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "yaml": "^2.4.2"
  }
}
